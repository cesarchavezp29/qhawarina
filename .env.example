# NEXUS Environment Variables
# Copy this file to .env and fill in the values

# Google Earth Engine (Phase 2 — VIIRS nighttime lights)
# GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
# GEE_KEY_FILE=path/to/key.json

# Data paths (optional overrides)
# NEXUS_DATA_DIR=./data
# NEXUS_RAW_DIR=./data/raw
# NEXUS_PROCESSED_DIR=./data/processed
